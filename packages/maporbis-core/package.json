{
  "name": "@maporbis/core",
  "version": "0.1.0-beta",
  "type": "module",
  "description": "MapOrbis Core - Open Source GIS Engine with Three.js",
  "author": {
    "name": "MapOrbis Team"
  },
  "license": "Apache-2.0",
  "keywords": [
    "three",
    "gis",
    "tile",
    "map",
    "3D",
    "webgl"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "three": "^0.182.0"
  },
  "dependencies": {
    "@pmndrs/vanilla": "^1.20.4",
    "d3-quadtree": "^3.0.1",
    "earcut": "^3.0.1",
    "fflate": "^0.8.2",
    "lodash": "^4.17.21",
    "potpack": "^1.0.2",
    "three-stdlib": "^2.36.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/d3-quadtree": "^3.0.6",
    "@types/earcut": "^3.0.0",
    "@types/geojson": "^7946.0.16",
    "@types/lodash": "^4.17.20",
    "@types/node": "^24.2.0",
    "@types/three": "^0.182.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.0.0",
    "jsdom": "^26.0.0",
    "three": "^0.182.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.0.0",
    "vitest-canvas-mock": "^0.3.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
